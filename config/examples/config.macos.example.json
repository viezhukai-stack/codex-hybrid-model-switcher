{
  "codex_home": "~/.codex",
  "cc_switch_home": "~/.cc-switch",
  "bridge": {
    "host": "127.0.0.1",
    "port": 19030,
    "llama_port": 19031,
    "idle_seconds": 600
  },
  "providers": [
    {
      "id": "openai-official",
      "label": "OpenAI Official",
      "kind": "official",
      "model": "gpt-5.5"
    },
    {
      "id": "cpamc-gpt-5-5",
      "label": "CPAMC GPT-5.5",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "CPAMC_API_KEY",
      "model": "gpt-5.5",
      "wire_api": "responses"
    },
    {
      "id": "cpamc-gpt-5-4",
      "label": "CPAMC GPT-5.4",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "CPAMC_API_KEY",
      "model": "gpt-5.4",
      "wire_api": "responses"
    },
    {
      "id": "cpamc-claude-opus-4-6-thinking",
      "label": "CPAMC Claude Opus 4.6 Thinking",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "CPAMC_API_KEY",
      "model": "claude-opus-4-6-thinking",
      "wire_api": "responses"
    },
    {
      "id": "cpamc-gemini-3-1-pro-preview",
      "label": "CPAMC Gemini 3.1 Pro Preview",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "CPAMC_API_KEY",
      "model": "gemini-3.1-pro-preview",
      "wire_api": "responses"
    },
    {
      "id": "cpamc-gemini-3-5-flash",
      "label": "CPAMC Gemini 3.5 Flash",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "CPAMC_API_KEY",
      "model": "gemini-3.5-flash",
      "wire_api": "responses"
    },
    {
      "id": "cpamc-grok-4-1-thinking",
      "label": "CPAMC Grok 4.1 Thinking",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "CPAMC_API_KEY",
      "model": "grok-4.1-thinking",
      "wire_api": "responses"
    },
    {
      "id": "local-gemma",
      "label": "Local Gemma",
      "kind": "local",
      "base_url": "http://127.0.0.1:19030/v1",
      "model": "local/gemma",
      "wire_api": "responses"
    }
  ],
  "local_model": {
    "id": "local/gemma",
    "display_name": "Local Gemma",
    "context_window": 8192,
    "llama_server_path": "~/path/to/llama-server",
    "model_path": "~/path/to/model.gguf",
    "mmproj_path": "~/path/to/mmproj.gguf",
    "system_prompt": "You are a concise local coding assistant running through llama.cpp.",
    "max_output_tokens": 512,
    "extra_args": [
      "--jinja",
      "--reasoning",
      "off",
      "--reasoning-format",
      "none",
      "--reasoning-budget",
      "0",
      "--no-mmproj-offload"
    ]
  }
}

