{
  "codex_home": "~/.codex",
  "cc_switch_home": "~/.cc-switch",
  "bridge": {
    "host": "127.0.0.1",
    "port": 19030,
    "llama_port": 19031,
    "idle_seconds": 600
  },
  "providers": [
    {
      "id": "openai-official",
      "label": "OpenAI Official",
      "kind": "official",
      "model": "gpt-5.5"
    },
    {
      "id": "cloud-gpt-main",
      "label": "Cloud GPT Main",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "OPENAI_COMPATIBLE_API_KEY",
      "model": "provider-gpt-main",
      "wire_api": "responses"
    },
    {
      "id": "cloud-gpt-secondary",
      "label": "Cloud GPT Secondary",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "OPENAI_COMPATIBLE_API_KEY",
      "model": "provider-gpt-secondary",
      "wire_api": "responses"
    },
    {
      "id": "cloud-claude-thinking",
      "label": "Cloud Claude Thinking",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "OPENAI_COMPATIBLE_API_KEY",
      "model": "provider-claude-thinking",
      "wire_api": "responses"
    },
    {
      "id": "cloud-gemini-pro",
      "label": "Cloud Gemini Pro",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "OPENAI_COMPATIBLE_API_KEY",
      "model": "provider-gemini-pro",
      "wire_api": "responses"
    },
    {
      "id": "cloud-gemini-flash",
      "label": "Cloud Gemini Flash",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "OPENAI_COMPATIBLE_API_KEY",
      "model": "provider-gemini-flash",
      "wire_api": "responses"
    },
    {
      "id": "cloud-grok-thinking",
      "label": "Cloud Grok Thinking",
      "kind": "cloud",
      "base_url": "https://YOUR-OPENAI-COMPATIBLE-ENDPOINT.example/v1",
      "api_key_env": "OPENAI_COMPATIBLE_API_KEY",
      "model": "provider-grok-thinking",
      "wire_api": "responses"
    },
    {
      "id": "local-gemma",
      "label": "Local Gemma",
      "kind": "local",
      "base_url": "http://127.0.0.1:19030/v1",
      "model": "local/gemma",
      "wire_api": "responses"
    }
  ],
  "local_model": {
    "id": "local/gemma",
    "display_name": "Local Gemma",
    "context_window": 8192,
    "llama_server_path": "~/path/to/llama-server",
    "model_path": "~/path/to/model.gguf",
    "mmproj_path": "~/path/to/mmproj.gguf",
    "system_prompt": "You are a concise local coding assistant running through llama.cpp.",
    "max_output_tokens": 512,
    "extra_args": [
      "--jinja",
      "--reasoning",
      "off",
      "--reasoning-format",
      "none",
      "--reasoning-budget",
      "0",
      "--no-mmproj-offload"
    ]
  }
}
